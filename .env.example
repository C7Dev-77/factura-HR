# ============================================================
# CONFIGURACIÓN DE SUPABASE - Factura LVL (Hijos del Rey)
# ============================================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a .env
# 2. Reemplaza los valores con tus credenciales de Supabase
# 3. Reinicia el servidor de desarrollo (npm run dev)
#
# Obtén estos valores desde:
# https://supabase.com/dashboard/project/_/settings/api
# ============================================================

# URL del proyecto Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# API Key pública (Anon Key)
# NOTA: La anon key es segura para el frontend.
# NUNCA coloques la "service_role key" aquí.
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui

# ============================================================
# IMPORTANTE - SEGURIDAD:
# - Este archivo (.env) NO debe subirse a GitHub
# - Está incluido en .gitignore
# - Para producción (Vercel), configura estas mismas
#   variables en: Vercel Dashboard > Settings > Environment Variables
# ============================================================
